# Oracle ARM Grabber - Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# Oracle Cloud tenancy OCID (from Console → Tenancy Details)
COMPARTMENT=ocid1.tenancy.oc1..YOUR_TENANCY_OCID

# Subnet OCID (from Networking → VCN → Subnets)
SUBNET_ID=ocid1.subnet.oc1.YOUR_SUBNET_OCID

# Image OCID (Ubuntu 24.04 aarch64, from Compute → Custom Images)
IMAGE_ID=ocid1.image.oc1.YOUR_IMAGE_OCID

# Availability Domain (from Compute → Create Instance → AD dropdown)
AD_NAME=YOUR_AVAILABILITY_DOMAIN

# Path to your SSH public key
SSH_KEY=$HOME/.ssh/oracle_ssh_key.pub
